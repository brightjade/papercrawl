# OpenReview credentials (free account: https://openreview.net/signup)
# Required for: iclr, neurips, icml, colm
# Not needed for: emnlp, acl, naacl
OPENREVIEW_USERNAME=your@email.com
OPENREVIEW_PASSWORD=your_password

# Semantic Scholar API key (optional, increases citation fetching rate limits)
# Get one at: https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=your_api_key
